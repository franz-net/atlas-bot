# Project Atlas — Environment Configuration
# Copy to .env and fill in your credentials

# TradeStation OAuth2
TS_API_KEY=
TS_API_SECRET=
TS_ACCOUNT_ID=
TS_BASE_URL=https://api.tradestation.com/v3
TS_SIM_URL=https://sim-api.tradestation.com/v3
TS_REDIRECT_URI=http://localhost:8080/callback
USE_SIM_ACCOUNT=true

# AI Provider Selection
DECISION_PROVIDER=claude              # claude | gemini

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=
CLAUDE_DECISION_MODEL=claude-sonnet-4-20250514
CLAUDE_REVIEW_MODEL=claude-opus-4-20250514

# Google (Gemini AI)
GEMINI_API_KEY=
GEMINI_DECISION_MODEL=gemini-2.5-flash

# Finnhub (Company News)
FINNHUB_API_KEY=

# Trading Parameters
WITHDRAWAL_THRESHOLD=10000           # Phase 2 withdrawal activates above this active capital

# Operator Approval (Phase A of live transition)
OPERATOR_APPROVAL=false              # true = require manual approval for each trade
AUTO_APPROVE_AFTER=0                 # Auto-approve after N approved trades (0 = never)
